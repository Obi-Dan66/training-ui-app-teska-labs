{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["DOM", "ES2020"],
      "jsx": "react-jsx",
  
      "module": "ESNext",
      "moduleResolution": "Bundler",
  
      "allowJs": true,
      "checkJs": false,
  
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
  
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
  
      "baseUrl": "src"
    },
    "include": ["src"]
  }